# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saferoute

# JWT Auth — generate a strong secret for production
JWT_SECRET=your-secret-key-here

# Google Maps API key (for Directions proxy — keep server-side only)
GOOGLE_MAPS_API_KEY=your-google-maps-key

# CORS — comma-separated allowed origins
CORS_ORIGINS=https://saferoute.kz,https://admin.saferoute.kz

# Rate limiting
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_REPORT=10/minute

# Optional: OpenAI for AI incident verification
OPENAI_API_KEY=

# Optional: Firebase for push notifications
FIREBASE_CREDENTIALS_PATH=
